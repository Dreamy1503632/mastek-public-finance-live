# Copy this file to .env for local testing (do NOT commit .env itself).
# On Vercel, set these same names as Environment Variables in the
# project dashboard instead (Settings -> Environment Variables).

AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com
AZURE_OPENAI_KEY=your_azure_openai_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Vercel Blob token - Vercel adds this automatically once you connect a
# Blob store to the project, you shouldn't need to set it by hand.
# BLOB_READ_WRITE_TOKEN=

# SMTP / email config - used by /api/email-report to send the assessment
# report to the visitor's inbox. Example values below are for Office 365;
# swap for whatever mailbox you're sending from.
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=reports@yourdomain.com
EMAIL_PASS=your_smtp_password_or_app_password
EMAIL_FROM=reports@yourdomain.com
EMAIL_FROM_NAME=Mastek AI
